public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*

# Resilient installs on slow/throttled networks (CI, Docker NAT, Fly builder).
fetch-timeout=600000
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
# Fewer parallel downloads => more bandwidth per file => fewer stalls on big tarballs.
network-concurrency=2

