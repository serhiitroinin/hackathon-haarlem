// Prisma schema. Docs: https://pris.ly/d/prisma-schema
// Postgres everywhere: Fly Postgres in prod, local Postgres via docker-compose
// for dev (see docker-compose.yml and DEPLOY.md). DATABASE_URL is the only knob.

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// One shared entity the whole demo hangs off of:
//  - the editor creates/edits `content`
//  - the map plots notes that have lat/lng
//  - the chart aggregates notes by day
//  - the chat agent can read/write these via a tool (see src/server/api/routers/note.ts)
model Note {
    id        String   @id @default(cuid())
    title     String
    content   String   @default("")
    lat       Float?
    lng       Float?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([createdAt])
}

// A Project is the top-level entity: one organization case we're working on.
// It holds the initial context plus every uploaded asset, and is what the
// sidebar lists / the chat is scoped to.
model Project {
    id        String   @id @default(cuid())
    title     String
    context   String   @default("") // free-text initial context from the wizard
    sources   Source[]
    decks     Deck[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([createdAt])
}

// A slide deck that belongs to a project (a project asset). `slides` holds the
// Slide[] JSON the builder edits; DeckVersion rows are point-in-time snapshots.
model Deck {
    id        String        @id @default(cuid())
    projectId String
    project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
    title     String
    slides    Json          // Slide[] from the builder
    versions  DeckVersion[]
    createdAt DateTime      @default(now())
    updatedAt DateTime      @updatedAt

    @@index([projectId])
}

model DeckVersion {
    id        String   @id @default(cuid())
    deckId    String
    deck      Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
    label     String   @default("")
    slides    Json
    createdAt DateTime @default(now())

    @@index([deckId])
}

// A source document attached to a project. Its extracted `text` becomes context
// for the chat and downstream training generation.
//  - kind: "pdf" | "image" | "text"
//  - text: extracted/plain text (empty for images we only kept for vision)
//  - chars: length of `text`, denormalized for quick UI display
model Source {
    id        String   @id @default(cuid())
    // Optional so `db push` can add it to pre-existing rows without a reset.
    // The app always sets it on upload; any null rows are pre-project orphans.
    projectId String?
    project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
    name      String
    kind      String
    mimeType  String
    bytes     Int
    text      String   @default("")
    chars     Int      @default(0)
    createdAt DateTime @default(now())

    @@index([projectId])
    @@index([createdAt])
}
