// Prisma schema. Docs: https://pris.ly/d/prisma-schema
// Postgres everywhere: Fly Postgres in prod, local Postgres via docker-compose
// for dev (see docker-compose.yml and DEPLOY.md). DATABASE_URL is the only knob.

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// One shared entity the whole demo hangs off of:
//  - the editor creates/edits `content`
//  - the map plots notes that have lat/lng
//  - the chart aggregates notes by day
//  - the chat agent can read/write these via a tool (see src/server/api/routers/note.ts)
model Note {
    id        String   @id @default(cuid())
    title     String
    content   String   @default("")
    lat       Float?
    lng       Float?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([createdAt])
}

// A source document uploaded on the first screen. Its extracted `text` becomes
// context for the next steps (the Maverx training generation reads these in).
//  - kind: "pdf" | "image" | "text"
//  - text: extracted/plain text (empty for images we only kept for vision)
//  - chars: length of `text`, denormalized for quick UI display
model Source {
    id        String   @id @default(cuid())
    name      String
    kind      String
    mimeType  String
    bytes     Int
    text      String   @default("")
    chars     Int      @default(0)
    createdAt DateTime @default(now())

    @@index([createdAt])
}
