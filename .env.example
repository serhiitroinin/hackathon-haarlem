# Copy to ".env" and fill in. ".env" is gitignored; this file is committed.
# When adding variables, update the schema in "/src/env.js" too.

# Prisma — Postgres. For local dev, `docker compose up -d` starts a Postgres
# matching the URL below. In prod, Fly sets this for you via `fly postgres attach`.
DATABASE_URL="postgresql://postgres:postgres@localhost:5455/haarlem?schema=public"

# --- AI ---
# Pick a provider: anthropic | openai | openrouter
AI_PROVIDER="anthropic"
AI_MODEL="claude-sonnet-4-6"
ANTHROPIC_API_KEY=""
# OPENAI_API_KEY=""
# OpenRouter (OpenAI-compatible) — Maverx provides €20 of credits per team.
# OPENROUTER_API_KEY=""
# With openrouter, use model ids like "anthropic/claude-sonnet-4.6".
# Optional: a stronger model just for training-content generation.
# AI_CONTENT_MODEL="claude-opus-4-8"

# --- Maps (optional) ---
# NEXT_PUBLIC_MAPTILER_KEY=""
